        <div class="hero-form-column">
            <div class="hero-header-block">
                <div class="hero-questions">
                    <h1>QUESTIONS?</h1>
                </div>
                <div class="hero-title-question">
                    <h2>Have a <span class="highlight-text-large">Question</span> <br> About Your Case?</h2>
